        "ja" : { "stringUnit" : { "state" : "translated", "value" : "メニューバーと設定画面の表示言語。\"System Default\" は macOS の言語設定に従います。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "菜单栏和设置窗口的显示语言。\"System Default\" 跟随 macOS 系统语言。" } }
