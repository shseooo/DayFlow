    "settings.permission_footer" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "권한 변경 후 잠시 기다리거나 앱을 재시작하면 자동으로 반영됩니다." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Permission changes apply after a short wait or app restart." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "権限の変更は少し待つかアプリを再起動すれば自動で反映されます。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "权限变更稍后自动生效,或重启应用。" } }
      }
