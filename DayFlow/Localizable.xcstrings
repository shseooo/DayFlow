        "ko" : { "stringUnit" : { "state" : "translated", "value" : "AI가 생성하는 요약문의 언어. UI 언어와 독립." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Language of AI-generated summaries. Independent of UI language." } },
