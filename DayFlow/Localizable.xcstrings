    "settings.watched_dirs" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "파일 변경 감시 디렉토리" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Watched Directories" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "監視ディレクトリ" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "监视目录" } }
      }
    },
    "settings.watched_dirs_footer" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "지정된 디렉토리의 파일 생성/수정/이동/삭제를 실시간으로 기록합니다." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Records file create/modify/rename/delete events in the listed directories in real time." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "指定ディレクトリのファイル作成/変更/移動/削除をリアルタイムで記録します。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "实时记录所列目录的文件创建/修改/重命名/删除事件。" } }
      }
    },
    "settings.add_dir" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "디렉토리 추가" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add Directory" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ディレクトリを追加" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "添加目录" } }
      }
    },
    "settings.excluded_dirs" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "변경 감시 제외 디렉토리" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Excluded Directories" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "監視除外ディレクトリ" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "排除目录" } }
      }
    },
    "settings.excluded_dirs_footer" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "경로의 일부가 이 목록에 매칭되면 변경 이벤트를 기록하지 않습니다. 예: minio 데이터 폴더, 임시 작업 폴더 등." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Skips change events for paths whose substring matches any item here. e.g. minio data folder, temp build folder." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "パスの一部がここに一致する場合、変更イベントを記録しません。例: minio データフォルダ、一時作業フォルダ。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "如果路径包含此列表中的任一项,则跳过对应的变更事件。例如 minio 数据文件夹、临时工作目录。" } }
      }
    },
    "settings.add_excluded_dir" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "제외 디렉토리 추가" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add Excluded Directory" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "除外ディレクトリを追加" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "添加排除目录" } }
      }
    },
    "settings.zsh_realtime" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "터미널 실시간 수집 (zsh)" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Terminal Real-time Collection (zsh)" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ターミナル リアルタイム収集 (zsh)" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "终端实时收集 (zsh)" } }
      }
    },
    "settings.zsh_explanation" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "zsh는 기본적으로 셸 종료 시점에만 history 파일에 기록합니다. 명령 실행 직후 실시간으로 수집하려면 ~/.zshrc 끝에 아래 옵션을 추가하세요." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "zsh writes to its history file only when the shell exits by default. To capture commands in real time, add the following options to the end of ~/.zshrc." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "zsh はデフォルトでシェル終了時のみ履歴ファイルへ書き込みます。実行直後にリアルタイムで収集するには、~/.zshrc の末尾に以下を追加してください。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "zsh 默认仅在 shell 退出时写入历史文件。要在命令执行后立即捕获,请在 ~/.zshrc 末尾添加以下选项。" } }
      }
    },
    "settings.zsh_apply_hint" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "적용 후 새 터미널을 열거나 `source ~/.zshrc`를 실행하세요." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Open a new terminal or run `source ~/.zshrc` to apply." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "適用するには新しいターミナルを開くか、`source ~/.zshrc` を実行してください。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "应用方式: 打开新终端或运行 `source ~/.zshrc`。" } }
      }
    },
    "settings.launch_at_login" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "로그인 시 자동 실행" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Launch at Login" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ログイン時に自動起動" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "登录时自动启动" } }
      }
    },
    "settings.autostart_section" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "자동 시작" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Auto-Start" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "自動起動" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "自动启动" } }
      }
    },
    "settings.autostart_footer" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "macOS 로그인 시 DayFlow를 자동으로 실행합니다. 첫 등록 후 시스템 설정 → 일반 → 로그인 항목에서 승인이 필요할 수 있습니다." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Launches DayFlow automatically at macOS login. After first registration, approval may be required in System Settings → General → Login Items." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "macOS ログイン時に DayFlow を自動起動します。初回登録後、システム設定 → 一般 → ログイン項目で承認が必要な場合があります。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "在 macOS 登录时自动启动 DayFlow。首次注册后,可能需要在系统设置 → 通用 → 登录项中批准。" } }
      }
    },
    "settings.current_status" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "현재 상태: %@" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Current status: %@" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "現在のステータス: %@" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前状态: %@" } }
      }
    },
    "settings.open_system_settings" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "시스템 설정 열기" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Open System Settings" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "システム設定を開く" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "打开系统设置" } }
      }
    },
    "settings.unstable_location_warning" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "⚠ 현재 앱이 Xcode DerivedData 또는 임시 폴더에서 실행 중입니다. /Applications로 옮긴 후 등록해야 부팅 시 정상 실행됩니다." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "⚠ The app is running from Xcode DerivedData or a temporary folder. Move it to /Applications before registering for login startup." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "⚠ アプリは Xcode DerivedData または一時フォルダから実行中です。起動時の自動実行を有効にする前に /Applications へ移動してください。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "⚠ 应用正在从 Xcode DerivedData 或临时文件夹运行。请先移动到 /Applications 再注册开机自启动。" } }
      }
    },
    "settings.permissions" : {
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "권한 상태" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Permissions" } },
